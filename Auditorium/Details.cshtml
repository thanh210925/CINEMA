@model CINEMA.Models.Auditorium
@{
    ViewData["Title"] = "Chi tiết phòng chiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <!-- Header -->
    <div class="p-4 rounded-3 mb-4 text-white header-gradient d-flex justify-content-between align-items-center shadow-sm">
        <div>
            <h3 class="fw-bold mb-1">👁 Chi tiết phòng chiếu</h3>
            <p class="mb-0 opacity-75">Thông tin cụ thể về phòng chiếu <strong>@Model.Name</strong></p>
        </div>
        <a asp-action="Index" class="btn btn-light fw-semibold px-4 py-2 shadow-sm rounded-pill">
            ↩ Quay lại danh sách
        </a>
    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header text-white text-center py-4 card-header-gradient">
            <h4 class="fw-bold mb-0">🎞 @Model.Name</h4>
        </div>

        <div class="card-body px-5 py-4">
            <dl class="row mb-0">
                <dt class="col-md-4 text-secondary fw-semibold">🎫 Tên phòng:</dt>
                <dd class="col-md-8">@Model.Name</dd>

                <dt class="col-md-4 text-secondary fw-semibold">🪑 Số hàng ghế:</dt>
                <dd class="col-md-8">@Model.SeatRows</dd>

                <dt class="col-md-4 text-secondary fw-semibold">🪑 Số cột ghế:</dt>
                <dd class="col-md-8">@Model.SeatCols</dd>

                <dt class="col-md-4 text-secondary fw-semibold">📽 Loại màn hình:</dt>
                <dd class="col-md-8">
                    <span class="badge bg-info text-dark px-3 py-2">@Model.ScreenType</span>
                </dd>

                <dt class="col-md-4 text-secondary fw-semibold">⚙️ Trạng thái:</dt>
                <dd class="col-md-8">
                    @if (Model.IsActive == true)
                    {
                        <span class="badge bg-success px-3 py-2">Đang hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary px-3 py-2">Ngừng hoạt động</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex justify-content-end mt-4">
        <a asp-action="Edit" asp-route-id="@Model.AuditoriumId" class="btn btn-primary px-4 rounded-pill shadow-sm me-2">
            ✏️ Sửa thông tin
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
            ⬅ Quay lại
        </a>
    </div>
</div>

<!-- Custom CSS -->
<style>
    .header-gradient {
        background: linear-gradient(90deg, #007bff, #00aaff);
    }

    .card-header-gradient {
        background: linear-gradient(90deg, #0069d9, #00aaff);
    }

    .card {
        border-radius: 1.2rem !important;
        transition: all 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 123, 255, 0.2);
    }

    dt {
        font-size: 1rem;
        color: #5a5a5a;
        margin-bottom: 6px;
    }

    dd {
        font-size: 1rem;
        color: #1d1d1d;
        margin-bottom: 14px;
    }

    .btn {
        transition: all 0.2s ease-in-out;
    }

    .btn-primary:hover {
        background-color: #0056b3;
        transform: scale(1.05);
    }

    .btn-outline-secondary:hover {
        background-color: #f1f1f1;
    }
</style>
