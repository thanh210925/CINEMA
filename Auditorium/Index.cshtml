@model IEnumerable<CINEMA.Models.Auditorium>
@{
    ViewData["Title"] = "Quản lý phòng chiếu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <!-- Header -->
    <div class="p-4 rounded-4 mb-4 text-white d-flex justify-content-between align-items-center header-gradient shadow-sm">
        <div>
            <h2 class="fw-bold mb-1">🏛️ Quản lý phòng chiếu</h2>
            <p class="mb-0 opacity-75 fs-6">Theo dõi, chỉnh sửa và quản lý danh sách phòng chiếu tại rạp</p>
        </div>
        <a asp-action="Create" class="btn btn-light fw-semibold px-4 py-2 shadow-sm rounded-pill">
            ➕ Thêm phòng chiếu
        </a>
    </div>

    <!-- Search box -->
    <div class="card border-0 shadow-sm mb-4 rounded-4">
        <div class="card-body py-3 px-4 d-flex justify-content-between align-items-center">
            <input type="text" id="searchInput"
                   class="form-control rounded-pill px-4 py-2 shadow-sm w-75 fs-6"
                   placeholder="🔍 Tìm kiếm theo tên phòng hoặc loại màn hình..." />
            <p class="text-muted mb-0 fs-6">Tổng số: <strong>@Model.Count()</strong> phòng chiếu</p>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm rounded-4">
        <table class="table align-middle mb-0 table-hover">
            <thead class="text-white text-center table-header-gradient fs-6">
                <tr>
                    <th class="py-3">#</th>
                    <th>Tên phòng</th>
                    <th>Ghế (Hàng x Cột)</th>
                    <th>Loại màn hình</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div>
                                <img src="https://cdn-icons-png.flaticon.com/512/4072/4072398.png" width="80" />
                                <p class="mt-3 mb-2 text-muted">Chưa có phòng chiếu nào</p>
                                <a asp-action="Create" class="btn btn-primary px-4 rounded-pill">Thêm phòng chiếu</a>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        <tr class="text-center fs-6">
                            <td>@i</td>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.SeatRows x @item.SeatCols</td>
                            <td><span class="badge bg-info-subtle text-dark px-3 py-2">@item.ScreenType</span></td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success px-3 py-2">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-3 py-2">Ngừng</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.AuditoriumId"
                                   class="btn btn-sm btn-outline-info me-1 rounded-pill px-3">👁 Xem</a>
                                <a asp-action="Edit" asp-route-id="@item.AuditoriumId"
                                   class="btn btn-sm btn-outline-warning me-1 rounded-pill px-3">✏️ Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.AuditoriumId"
                                   class="btn btn-sm btn-outline-danger rounded-pill px-3">🗑 Xóa</a>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Custom CSS -->
<style>
    .header-gradient {
        background: linear-gradient(90deg, #6a9eff, #89c3ff);
    }

    .table-header-gradient {
        background: linear-gradient(90deg, #558cff, #76b6ff);
    }

    .table thead th {
        border: none;
        font-weight: 600;
    }

    .table tbody tr:hover {
        background-color: #f1f7ff !important;
        transition: all 0.2s ease-in-out;
    }

    .btn-outline-info:hover {
        background-color: #0dcaf0;
        color: white !important;
    }

    .btn-outline-warning:hover {
        background-color: #ffc107;
        color: white !important;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        color: white !important;
    }

    .form-control:focus {
        border-color: #6a9eff;
        box-shadow: 0 0 0 0.2rem rgba(106, 158, 255, 0.3);
    }

    .card {
        border-radius: 1rem;
    }

    .badge {
        font-size: 0.85rem;
    }
</style>

<!-- Search Script -->
<script>
    document.getElementById("searchInput").addEventListener("input", function () {
        const search = this.value.toLowerCase();
        document.querySelectorAll("#tableBody tr").forEach(row => {
            const text = row.innerText.toLowerCase();
            row.style.display = text.includes(search) ? "" : "none";
        });
    });
</script>
